generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DELIVERED
}

enum PlanType {
  WEEK
  MONTH
  YEAR
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  firstName   String
  lastName    String
  email       String
  dateOfBirth DateTime
  photoUrl    String

  planType PlanType
  amount   Int
  status   OrderStatus @default(PENDING)

  stripeSessionId String?   @unique
  stripePaidAt    DateTime?

  accountEmail    String?
  accountPassword String?
  accountExpiry   DateTime?

  magicToken       String?   @unique
  magicTokenExpiry DateTime?

  // Affiliation
  affiliateCode String?

  // Issue reporting
  accountIssueReported   Boolean   @default(false)
  accountIssueReportedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveredAt DateTime?

  referral AffiliateReferral?

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([affiliateCode])
}

model Affiliate {
  id          String          @id @default(cuid())
  email       String          @unique
  firstName   String
  lastName    String
  code        String          @unique
  balance     Int             @default(0)  // centimes
  totalEarned Int             @default(0)  // centimes
  status      AffiliateStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  referrals AffiliateReferral[]
}

model AffiliateReferral {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  commission  Int       // centimes
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
}
