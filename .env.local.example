# ============================================
# NaviPass — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================

# === Base de données (Neon PostgreSQL) ===
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# === Stripe ===
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Créez ces prix dans le dashboard Stripe
STRIPE_PRICE_WEEK="price_..."
STRIPE_PRICE_MONTH="price_..."
STRIPE_PRICE_YEAR="price_..."

# === Resend (emails) ===
RESEND_API_KEY="re_..."
EMAIL_FROM="NaviPass <noreply@votredomaine.com>"

# === Admin ===
ADMIN_EMAIL="admin@votredomaine.com"
ADMIN_PASSWORD="votre-mot-de-passe-fort-ici"

# === Sécurité ===
# JWT_SECRET: chaîne aléatoire longue (min 32 chars)
# Générez avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="07dd4bdf43be066f34e84b0619daec131ee0f15bc6cd32c75c4a2532ca884d4a90a054c0df56b44234931c617cc1e852"

ENCRYPTION_KEY="6e24630273d48df4481f0ecb6b0310621904b32bff686a9adce2a4dacafd44f6"

# === Application ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# En production: NEXT_PUBLIC_APP_URL="https://votredomaine.com"
